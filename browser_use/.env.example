# Number of runs to execute
RUNS=3

# Number of HN stories to visit per run (mirrors index.ts default of 10)
N_STORIES=10

# Groq model name (see https://console.groq.com/docs/models)
# Groq free-tier models: llama-3.3-70b-versatile, llama3-70b-8192, mixtral-8x7b-32768
# browser-use verified models: meta-llama/llama-4-scout-17b-16e-instruct, qwen/qwen3-32b
MODEL_NAME=llama-3.3-70b-versatile

# Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
